# Reference document parser
MINERU_API_BASE_URL=https://mineru.net/api/v4
MINERU_APPLY_UPLOAD_URL=https://mineru.net/api/v4/file-urls/batch
MINERU_BATCH_RESULT_URL_PREFIX=https://mineru.net/api/v4/extract-results/batch
# Bearer token from MinerU console
MINERU_API_TOKEN=
MINERU_MODEL_VERSION=vlm

# Optional parser controls
MINERU_LANGUAGE=ch
MINERU_ENABLE_FORMULA=true
MINERU_ENABLE_TABLE=true
MINERU_ENABLE_OCR=false
MINERU_POLLING_INTERVAL_SECONDS=2
MINERU_MAX_POLLING_ATTEMPTS=40

# LLM endpoint for lesson-plan materialization smoke tests
# OpenAI-compatible example: https://right.codes/codex/v1
# Claude-compatible example: https://www.right.codes/claude/v1/messages
EDUNODE_LLM_BASE_URL=
EDUNODE_LLM_MODEL=
EDUNODE_LLM_API_KEY=
# Absolute path to a local reference template PDF used by smoke tests.
EDUNODE_REFERENCE_TEMPLATE_PATH=
